# Auth
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@evolutionchat.com
ADMIN_PASSWORD=your_secure_password

# Evolution API
EVOLUTION_API_URL=http://YOUR_SERVER_IP:8080
EVOLUTION_API_KEY=your_evolution_api_key

# Chatwoot
CHATWOOT_API_URL=http://YOUR_SERVER_IP:3000
CHATWOOT_ACCOUNT_ID=2
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_INTERNAL_URL=http://chatwoot-rails:3000

# Evolution Webhook (URL que o Chatwoot usa para chamar o Evolution - via Docker network)
EVOLUTION_WEBHOOK_BASE=http://evolution-api:8080

# Proxy (IPRoyal)
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_PROTOCOL=http
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_base_password
